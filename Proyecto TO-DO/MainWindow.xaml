<Window x:Class="Proyecto_TO_DO.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto_TO_DO"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="TO-DO" Height="450" Width="800">

    <Window.Resources>
        <!-- Style global para controles interactivos -->
        <Style TargetType="Button" x:Key="EstiloBoton">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ESTILO ESPECÍFICO PARA BOTÓN AGREGAR (Control circular) -->
        <Style x:Key="EstiloBotonAgregar"
               TargetType="Button"
               BasedOn="{StaticResource EstiloBoton}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="circle"
                                     Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle"
                                        Property="Opacity"
                                        Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="circle"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para ListBoxItem -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Proveedor de valores del enum Prioridad -->
        <ObjectDataProvider x:Key="PrioridadesProvider"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:Prioridad"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- DataTemplate para cada tarea con edición y DataTriggers -->
        <DataTemplate x:Key="DataTemplateTarea">
            <Border x:Name="rootBorder"
                    Padding="8" Margin="4"
                    CornerRadius="4"
                    BorderThickness="1"
                    BorderBrush="#DDDDDD"
                    Background="White">
                <StackPanel Orientation="Horizontal">
                    <!-- Actualizar Completada -->
                    <CheckBox IsChecked="{Binding Completada}"
                              Margin="0,0,8,0"
                              VerticalAlignment="Top"/>

                    <StackPanel>
                        <!-- Actualizar Nombre (editable) -->
                        <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                 FontWeight="Bold"
                                 BorderThickness="0"
                                 Background="Transparent"/>

                        <TextBlock Text="{Binding FechaLimite, StringFormat='{}{0:dd/MM/yyyy}'}"
                                   FontSize="11"
                                   Foreground="Gray"/>

                        <!-- Actualizar Prioridad (editable) -->
                        <ComboBox ItemsSource="{Binding Source={StaticResource PrioridadesProvider}}"
                                  SelectedItem="{Binding Prioridad}"
                                  Width="100"
                                  FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <DataTemplate.Triggers>
                <!-- Si la tarea está completada: fondo atenuado -->
                <DataTrigger Binding="{Binding Completada}" Value="True">
                    <Setter TargetName="rootBorder"
                            Property="UIElement.Opacity"
                            Value="0.5"/>
                    <Setter TargetName="rootBorder"
                            Property="Border.BorderBrush"
                            Value="#AAAAAA"/>
                </DataTrigger>

                <!-- Si la prioridad es Alta: borde rojo y más grueso -->
                <DataTrigger Binding="{Binding Prioridad}" Value="Alta">
                    <Setter TargetName="rootBorder"
                            Property="Border.BorderBrush"
                            Value="Red"/>
                    <Setter TargetName="rootBorder"
                            Property="Border.BorderThickness"
                            Value="2"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Panel de entrada (Crear) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBox x:Name="txtNombre" Width="200" Margin="0,0,10,0"
                     Text="{Binding NuevaTarea.Nombre, UpdateSourceTrigger=PropertyChanged}"/>

            <DatePicker x:Name="dpFecha" Width="120" Margin="0,0,10,0"
                        SelectedDate="{Binding NuevaTarea.FechaLimite}"/>

            <ComboBox x:Name="cbPrioridad"
                      Width="100"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding Source={StaticResource PrioridadesProvider}}"
                      SelectedItem="{Binding NuevaTarea.Prioridad}"/>

            <Button x:Name="btnAgregar"
                    Content="+"
                    Click="BtnAgregar_Click"
                    Style="{StaticResource EstiloBotonAgregar}"/>

            <Button x:Name="btnLimpiar"
                    Content="🗑️ Limpiar"
                    Click="BtnLimpiar_Click"
                    Style="{StaticResource EstiloBoton}"/>
        </StackPanel>

        <!-- Lista de tareas -->
        <ListBox x:Name="lbTareas"
                 Grid.Row="1"
                 ItemsSource="{Binding Tareas}"
                 ItemTemplate="{StaticResource DataTemplateTarea}"/>
    </Grid>
</Window>
